    "db:audit-eventos-ids-v2": "node scripts/audit-eventos-ids-v2.mjs",
    "db:cleanup-usuarios-test": "node scripts/cleanup-usuarios-test.mjs",
    "firestore:create": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/seed-v2/crear-base-firestore.ps1",
    "backup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/crear-copia-seguridad.ps1"
