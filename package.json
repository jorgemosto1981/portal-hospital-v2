{
  "name": "portal-hospital-v2",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "npm run dev --prefix web",
    "build:web": "npm run build --prefix web",
    "preview:web": "npm run preview --prefix web",
    "firebase": "firebase --config firebase-v2/firebase.json",
    "firebase:emulators": "firebase emulators:start --config firebase-v2/firebase.json",
    "firebase:emulators:with-functions": "firebase emulators:start --config firebase-v2/firebase.json --only firestore,functions,ui",
    "firebase:deploy:firestore": "firebase deploy --project portal-hospital-v2 --config firebase-v2/firebase.json --only firestore:rules,firestore:indexes",
    "firebase:deploy:functions": "firebase deploy --project portal-hospital-v2 --config firebase-v2/firebase.json --only functions",
    "verify:pre-coding": "node scripts/seed-v2/verify-pre-coding.mjs",
    "test:firestore:v2": "node scripts/seed-v2/test-firestore-v2-connection.mjs",
    "seed:cfg": "node scripts/seed-v2/seed-cfg.mjs",
    "firestore:create": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/seed-v2/crear-base-firestore.ps1"
  },
  "devDependencies": {
    "firebase-admin": "^13.6.0",
    "firebase-tools": "^15.15.0"
  },
  "dependencies": {
    "firebase": "^12.12.1"
  }
}
