rules_version = '2';

// V2 — esquema distinto de V1 (personas, usuarios_cuenta, cfg_*, …).
// Reemplazar por reglas según docs/v2/ACCESO_Y_RULES_FIRESTORE_V2.md antes de abrir tráfico a producción.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
