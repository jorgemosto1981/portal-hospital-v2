rules_version = '2';

// V2 — Fase 2: cfg_* (lectura autenticada) + usuarios_cuenta (lectura propia por auth_uid) + personas (lectura propia por claim persona_id).
// Matriz: docs/v2/ACCESO_Y_RULES_FIRESTORE_V2.md · claims: MODULO_LOGIN_V2 §3.3 (`syncSessionClaims`).
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Catálogos volcados por seed:cfg (MODULO_CONFIGURACION_V2) — escritura solo Admin/seed.
    match /cfg_estado_cuenta_acceso/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /cfg_estado_perfil_datos/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /cfg_tipo_evento/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Roles de aplicación (`usuarios_cuenta.role_ids[]` → `cfg_rol`); seed `scripts/seed-v2/seed-cfg.mjs`.
    match /cfg_rol/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // Cuenta operativa: el agente solo lee su fila (auth_uid == sesión). Escrituras vía Callables/Admin.
    match /usuarios_cuenta/{cuentaId} {
      allow read: if signedIn() && resource.data.auth_uid == request.auth.uid;
      allow write: if false;
    }

    // Ficha persona: id de documento = `per_<ULID>` = claim `persona_id` (tras syncSessionClaims + getIdToken(true)).
    match /personas/{personaId} {
      allow read: if signedIn() && request.auth.token.persona_id == personaId;
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
