rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isImage() {
      return request.resource != null
        && request.resource.contentType.matches('image/.*');
    }

    function isUnder5Mb() {
      return request.resource != null
        && request.resource.size < 5 * 1024 * 1024;
    }

    function isUnder10Mb() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024;
    }

    function isCertificadoMedico() {
      return request.resource != null
        && (
          request.resource.contentType.matches('application/pdf')
          || request.resource.contentType.matches('image/.*')
        );
    }

    // Certificados — aviso médico Caja Negra (solo el titular sube en su carpeta)
    match /avisos-med/{year}/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && isCertificadoMedico()
        && isUnder10Mb();
    }

    // Foto de rostro de legajo de personas
    match /personas/foto_rostro/{dni}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isImage() && isUnder5Mb();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
