# portal-hospital-v2 — credenciales del registro "Web" de Firebase
# 1) Copiá a .env.v2.local (ignorado por git; el patrón *.local ya cubre este archivo)
# 2) Integrá con Vite en ../portal-hospital-v1/portal-hospital/ (ver README.md en esta raíz) o otra app que cargue VITE_V2_*
#
# El cliente usa siempre Firebase en la nube (Firestore, Auth, Storage, Cloud Functions).
# Módulo de código: `src/firebaseConfig.v2.js` (esta carpeta).

VITE_V2_FIREBASE_API_KEY=your-api-key
VITE_V2_FIREBASE_AUTH_DOMAIN=portal-hospital-v2.firebaseapp.com
VITE_V2_FIREBASE_PROJECT_ID=portal-hospital-v2
VITE_V2_FIREBASE_STORAGE_BUCKET=portal-hospital-v2.firebasestorage.app
VITE_V2_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_V2_FIREBASE_APP_ID=your-app-id
# Opcional (recomendado en web para Analytics)
VITE_V2_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Opcional: app web (`web/`) — abrir el shell (Inicio, Configuración, etc.) sin pantalla de login. Solo local.
# VITE_BYPASS_AUTH=true

# ---- Scripts Node (Firebase Admin) en esta raíz: `npm run seed:cfg`, etc. ----
# Ruta absoluta al JSON de cuenta de servicio de GCP (mismo proyecto que V2). Sin comillas salvo que la ruta tenga espacios.
# GOOGLE_APPLICATION_CREDENTIALS=C:\ruta\service-account-v2.json
# Opcional si hace falta fijar proyecto: FIREBASE_V2_PROJECT_ID=portal-hospital-v2
